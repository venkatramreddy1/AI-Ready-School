{
  "version": 2,
  "buildCommand": "echo 'No build needed'",
  "outputDirectory": "./",
  "framework": "html",
  "routes": [
    {
      "src": "/styles.css",
      "dest": "/styles.css"
    },
    {
      "src": "/script.js",
      "dest": "/script.js"
    },
    {
      "src": "/(.*)\\.html",
      "dest": "/$1.html"
    },
    {
      "src": "/.*",
      "dest": "/index.html"
    }
  ]
}
